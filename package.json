{
  "name": "crm.cli",
  "version": "0.1.2",
  "description": "Headless CLI-first CRM",
  "author": "David Zhang",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dzhng/crm.cli.git"
  },
  "type": "module",
  "bin": {
    "crm": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "bun build src/cli.ts --outdir dist --target node --format esm --external @libsql/client --external drizzle-orm --external commander --external libphonenumber-js --external normalize-url --external toml --external ulid",
    "crm": "bun run src/cli.ts",
    "check-types": "tsc --noEmit",
    "test": "bun test --timeout 30000",
    "lint": "ultracite fix",
    "prepublishOnly": "bun run build",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,jsonc,css,scss,md,mdx}": [
      "npx ultracite fix"
    ]
  },
  "dependencies": {
    "@libsql/client": "^0.17.0",
    "commander": "^13.1.0",
    "drizzle-orm": "^0.45.1",
    "libphonenumber-js": "^1.12.0",
    "normalize-url": "^9.0.0",
    "toml": "^3.0.0",
    "ulid": "^2.3.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@types/bun": "^1.2.10",
    "drizzle-kit": "^0.31.9",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "typescript": "~5.9.3",
    "ultracite": "^7.2.3"
  }
}
